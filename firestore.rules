rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function authEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasOwnUserDoc() {
      return signedIn() && exists(userDocPath(authUid()));
    }

    function ownUserDoc() {
      return get(userDocPath(authUid()));
    }

    function userRole() {
      return hasOwnUserDoc() ? ownUserDoc().data.role : "";
    }

    function userInstituteId() {
      return hasOwnUserDoc() ? ownUserDoc().data.instituteId : "";
    }

    function ownTeacherId() {
      return hasOwnUserDoc() ? ownUserDoc().data.teacherId : "";
    }

    function ownEmployeeId() {
      return hasOwnUserDoc() ? ownUserDoc().data.employeeId : "";
    }

    function ownFullName() {
      return hasOwnUserDoc() ? ownUserDoc().data.fullName : "";
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isPrincipal() {
      return userRole() == "principal";
    }

    function isTeacher() {
      return userRole() == "teacher";
    }

    function isHod() {
      return userRole() == "hod";
    }

    function isClerk() {
      return userRole() == "clerk";
    }

    function isPeon() {
      return userRole() == "peon";
    }

    function isStudent() {
      return userRole() == "student";
    }

    function isPrivilegedInstituteRole() {
      return isAdmin() || isPrincipal() || isHod() || isClerk();
    }

    function isApprovedCampusUser() {
      return isAdmin() || isPrincipal() || isTeacher() || isHod() || isClerk() || isPeon() || isStudent();
    }

    function sameInstitute(instituteId) {
      return signedIn() && instituteId != null && userInstituteId() == instituteId;
    }

    function ownUserOrSameEmail() {
      return signedIn() &&
        (resource.data.uid == authUid() ||
          (authEmail() != "" && resource.data.email == authEmail()));
    }

    function userKeys() {
      return [
        "uid",
        "email",
        "fullName",
        "role",
        "instituteId",
        "instituteName",
        "department",
        "branch",
        "enrollment",
        "division",
        "semester",
        "academicYear",
        "subject",
        "teacherId",
        "employeeId"
      ];
    }

    function validPendingRequestPayload(requestId) {
      return request.resource.data.keys().hasOnly([
          "email",
          "fullName",
          "role",
          "instituteId",
          "instituteName",
          "department",
          "branch",
          "enrollment",
          "division",
          "semester",
          "academicYear",
          "subject",
          "teacherId",
          "employeeId",
          "status",
          "requestedAt",
          "approvedAt",
          "approvedBy",
          "rejectedAt",
          "rejectedBy"
        ]) &&
        request.resource.data.email == requestId &&
        request.resource.data.status == "pending" &&
        request.resource.data.approvedAt == 0 &&
        request.resource.data.approvedBy == "" &&
        request.resource.data.rejectedAt == 0 &&
        request.resource.data.rejectedBy == "";
    }

    function canReadStudent() {
      return isAdmin() ||
        (isPrivilegedInstituteRole() && sameInstitute(resource.data.instituteId)) ||
        (isStudent() && resource.data.userId == authUid()) ||
        (isTeacher() && sameInstitute(resource.data.instituteId));
    }

    function canReadStaff() {
      return isAdmin() ||
        (isPrivilegedInstituteRole() && sameInstitute(resource.data.instituteId)) ||
        (isTeacher() && resource.data.userId == authUid());
    }

    match /institutes/{instituteId} {
      allow read: if isApprovedCampusUser();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || ownUserOrSameEmail() || (isPrivilegedInstituteRole() && sameInstitute(resource.data.instituteId));
      allow create: if isAdmin() || (
        signedIn() &&
        authUid() == userId &&
        request.resource.data.keys().hasOnly(userKeys()) &&
        request.resource.data.uid == authUid() &&
        request.resource.data.email == authEmail()
      );
      allow update: if isAdmin() || (
        signedIn() &&
        authUid() == userId &&
        resource.data.uid == authUid() &&
        request.resource.data.keys().hasOnly(userKeys()) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();
    }

    match /users/{userId}/assistant/{documentId} {
      allow read, create, update, delete: if signedIn() && authUid() == userId;
    }

    match /students/{studentId} {
      allow read: if canReadStudent();
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /staff/{staffId} {
      allow read: if canReadStaff();
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /classes/{classId} {
      allow read: if isApprovedCampusUser() && sameInstitute(resource.data.instituteId);
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /subjects/{subjectId} {
      allow read: if isApprovedCampusUser() && sameInstitute(resource.data.instituteId);
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /teacherAssignments/{assignmentId} {
      allow read: if isAdmin() ||
        (isPrivilegedInstituteRole() && sameInstitute(resource.data.instituteId)) ||
        (isTeacher() && sameInstitute(resource.data.instituteId) && (
          resource.data.teacherId == authUid() ||
          resource.data.teacherId == ownTeacherId() ||
          resource.data.teacherId == ownEmployeeId() ||
          resource.data.teacherName == ownFullName()
        ));
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() ||
        (isPrivilegedInstituteRole() && sameInstitute(resource.data.instituteId)) ||
        (isTeacher() && (resource.data.teacherId == authUid() || resource.data.teacherId == ownUserDoc().data.employeeId)) ||
        (isStudent() && resource.data.studentUserId == authUid());
      allow create, update, delete: if isAdmin() ||
        (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId)) ||
        (isTeacher() && (request.resource.data.teacherId == authUid() || request.resource.data.teacherId == ownUserDoc().data.employeeId));
    }

    match /notices/{noticeId} {
      allow read: if isApprovedCampusUser() && sameInstitute(resource.data.instituteId);
      allow create, update, delete: if isAdmin() || (isPrivilegedInstituteRole() && sameInstitute(request.resource.data.instituteId));
    }

    match /assignments/{assignmentId} {
      allow read: if isApprovedCampusUser();
      allow create, update, delete: if isTeacher() || isHod() || isPrincipal();
    }

    match /events/{eventId} {
      allow read: if isApprovedCampusUser();
      allow create, update, delete: if isTeacher() || isHod() || isPrincipal();
    }

    match /schedule/{scheduleId} {
      allow read: if isApprovedCampusUser();
      allow create, update, delete: if isTeacher() || isHod() || isPrincipal();
    }

    match /reminders/{reminderId} {
      allow read: if isApprovedCampusUser();
      allow create, update, delete: if isTeacher() || isHod() || isPrincipal();
    }

    match /accountRequests/{requestId} {
      allow create: if validPendingRequestPayload(requestId);
      allow update: if isAdmin() || (
        validPendingRequestPayload(requestId) &&
        resource.data.status == "rejected" &&
        resource.data.email == requestId
      );
      allow read, delete: if isAdmin();
    }
  }
}
