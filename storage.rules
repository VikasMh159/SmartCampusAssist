rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function hasOwnUserDoc() {
      return signedIn() && firestore.exists(userDocPath());
    }

    function ownUserDoc() {
      return firestore.get(userDocPath());
    }

    function userRole() {
      return hasOwnUserDoc() ? ownUserDoc().data.role : "";
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isTeacher() {
      return userRole() == "teacher";
    }

    function isStudent() {
      return userRole() == "student";
    }

    function isApprovedCampusUser() {
      return isAdmin() || isTeacher() || isStudent();
    }

    match /assignments/{teacherId}/{fileName} {
      allow read: if isApprovedCampusUser();
      allow write: if isTeacher();
    }

    match /events/{teacherId}/{fileName} {
      allow read: if isApprovedCampusUser();
      allow write: if isTeacher();
    }
  }
}
